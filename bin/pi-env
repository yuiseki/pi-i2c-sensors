#!/usr/bin/env python3
"""pi-env : read environment sensors (Bosch BME280 + Vishay VEML7700).

BME280 gives temperature / humidity / pressure (I2C 0x77 or 0x76).
VEML7700 gives ambient light in lux (I2C 0x10). Either sensor may be absent;
each is reported with its own presence flag.

Default (no args): one-shot. Take a single measurement, print a human line,
also publish to /dev/shm/pi-env, and exit. A plain non-interactive CLI.

--daemon (-d): keep measuring ~every 2 s and publishing; used by the systemd
unit.

Published line on /dev/shm/pi-env (tmpfs = RAM):
  "<temp_c> <humidity_pct> <pressure_hpa> <bme_have> <lux> <lux_have>"
The first four fields are unchanged from the BME280-only version (so existing
consumers keep working); lux + its presence flag are appended.

i2c group, auto-sudo. Dependency-light: Bosch float compensation inlined and
VEML7700 lux computed directly, no driver libs. Harmless with no sensors.
"""
import os, sys, time

try:
    from smbus2 import SMBus
except ImportError:
    try:
        from smbus import SMBus
    except ImportError:
        SMBus = None

OUT = "/dev/shm/pi-env"
ADDRS = (0x77, 0x76)        # BME280
VEML_ADDR = 0x10            # VEML7700 ambient light


def open_bus():
    if SMBus is None:
        return None
    try:
        return SMBus(1)
    except PermissionError:
        os.execvp("sudo", ["sudo", sys.executable] + sys.argv)
    except OSError:
        return None


def s16(v):
    return v - 65536 if v >= 32768 else v


def s12(v):
    return v - 4096 if v >= 2048 else v


def s8(v):
    return v - 256 if v >= 128 else v


def find(bus):
    if bus is None:
        return None
    for a in ADDRS:
        try:
            if bus.read_byte_data(a, 0xD0) == 0x60:   # BME280 chip id
                return a
        except OSError:
            pass
    return None


def read_calib(bus, a):
    c = bus.read_i2c_block_data(a, 0x88, 26)
    h = bus.read_i2c_block_data(a, 0xE1, 7)
    d = {
        "T1": c[0] | c[1] << 8,
        "T2": s16(c[2] | c[3] << 8),
        "T3": s16(c[4] | c[5] << 8),
        "P1": c[6] | c[7] << 8,
        "P2": s16(c[8] | c[9] << 8),
        "P3": s16(c[10] | c[11] << 8),
        "P4": s16(c[12] | c[13] << 8),
        "P5": s16(c[14] | c[15] << 8),
        "P6": s16(c[16] | c[17] << 8),
        "P7": s16(c[18] | c[19] << 8),
        "P8": s16(c[20] | c[21] << 8),
        "P9": s16(c[22] | c[23] << 8),
        "H1": c[25],
        "H2": s16(h[0] | h[1] << 8),
        "H3": h[2],
        "H4": s12((h[3] << 4) | (h[4] & 0x0F)),
        "H5": s12((h[5] << 4) | (h[4] >> 4)),
        "H6": s8(h[6]),
    }
    return d


def configure(bus, a):
    bus.write_byte_data(a, 0xF2, 0x01)   # ctrl_hum: humidity oversample x1
    bus.write_byte_data(a, 0xF5, 0x00)   # config: no filter (forced mode per read)


def measure(bus, a, d):
    r = bus.read_i2c_block_data(a, 0xF7, 8)
    praw = (r[0] << 12) | (r[1] << 4) | (r[2] >> 4)
    traw = (r[3] << 12) | (r[4] << 4) | (r[5] >> 4)
    hraw = (r[6] << 8) | r[7]

    v1 = (traw / 16384.0 - d["T1"] / 1024.0) * d["T2"]
    v2 = (traw / 131072.0 - d["T1"] / 8192.0)
    v2 = v2 * v2 * d["T3"]
    tfine = v1 + v2
    temp = tfine / 5120.0

    v1 = tfine / 2.0 - 64000.0
    v2 = v1 * v1 * d["P6"] / 32768.0
    v2 = v2 + v1 * d["P5"] * 2.0
    v2 = v2 / 4.0 + d["P4"] * 65536.0
    v1 = (d["P3"] * v1 * v1 / 524288.0 + d["P2"] * v1) / 524288.0
    v1 = (1.0 + v1 / 32768.0) * d["P1"]
    if v1 == 0:
        press = 0.0
    else:
        p = 1048576.0 - praw
        p = (p - v2 / 4096.0) * 6250.0 / v1
        v1 = d["P9"] * p * p / 2147483648.0
        v2 = p * d["P8"] / 32768.0
        press = (p + (v1 + v2 + d["P7"]) / 16.0) / 100.0

    h = tfine - 76800.0
    h = (hraw - (d["H4"] * 64.0 + d["H5"] / 16384.0 * h)) * (
        d["H2"] / 65536.0 * (1.0 + d["H6"] / 67108864.0 * h *
                             (1.0 + d["H3"] / 67108864.0 * h)))
    h = h * (1.0 - d["H1"] * h / 524288.0)
    hum = max(0.0, min(100.0, h))
    return temp, hum, press


def measure_forced(bus, a, d):
    bus.write_byte_data(a, 0xF4, 0x25)   # T x1, P x1, forced mode (one shot)
    time.sleep(0.02)                     # ~9 ms max conversion at x1
    return measure(bus, a, d)


# --- VEML7700 ambient light ------------------------------------------------
# No chip-id register, so presence is "does 0x10 answer". Config reg 0x00 is a
# 16-bit LSB-first word: bits[12:11]=gain, bits[9:6]=integration time, bit0=
# shutdown. ALS data is reg 0x04. Lux = raw * resolution, where resolution
# scales inversely with gain and integration time (0.0036 lx/count at the most
# sensitive gain x2 / IT 800 ms). Auto-range: start wide (low gain, short IT)
# and step up sensitivity only while the reading is small, so it stays accurate
# from bright sunlight down to a dim room without saturating.
#   gain bits: x1=0b00, x2=0b01, x1/8=0b10, x1/4=0b11
#   IT bits:   100ms=0b0000, 200=0b0001, 400=0b0010, 800=0b0011, 50=0b1000, 25=0b1100
VEML_SEQ = [
    # (gain_bits, gain_factor, it_bits, it_ms)
    (0b10, 0.125, 0b0000, 100),   # x1/8, 100 ms  (widest range)
    (0b00, 1.0,   0b0000, 100),   # x1,   100 ms
    (0b01, 2.0,   0b0000, 100),   # x2,   100 ms
    (0b01, 2.0,   0b0001, 200),   # x2,   200 ms
    (0b01, 2.0,   0b0011, 800),   # x2,   800 ms  (most sensitive)
]


def veml_present(bus):
    if bus is None:
        return False
    try:
        bus.read_word_data(VEML_ADDR, 0x00)
        return True
    except OSError:
        return False


def veml_read_lux(bus):
    """Auto-ranged ambient light in lux (raises OSError if the sensor goes)."""
    raw = 0
    res = 0.0
    for gain_bits, gf, it_bits, it_ms in VEML_SEQ:
        conf = (gain_bits << 11) | (it_bits << 6)   # PERS/INT/SD = 0 (ALS on)
        bus.write_word_data(VEML_ADDR, 0x00, conf)
        time.sleep(it_ms / 1000.0 + 0.05)           # wait past one integration
        raw = bus.read_word_data(VEML_ADDR, 0x04)
        res = 0.0036 * (2.0 / gf) * (800.0 / it_ms)
        if raw > 100:                                # enough signal here
            break
    return raw * res


def publish(t, h, p, have, lux, lux_have):
    tmp = OUT + ".tmp"
    try:
        with open(tmp, "w") as fh:
            fh.write("%.2f %.1f %.1f %d %.1f %d\n"
                     % (t, h, p, 1 if have else 0, lux, 1 if lux_have else 0))
        os.replace(tmp, OUT)
    except OSError:
        pass


def read_lux(bus):
    """Return (lux, present). Never raises."""
    try:
        if veml_present(bus):
            return veml_read_lux(bus), True
    except OSError:
        pass
    return 0.0, False


def main():
    # Default: one-shot (measure once, print + publish, exit) so it is a plain
    # non-interactive CLI. --daemon keeps publishing for the map (used by the
    # systemd unit).
    daemon = ("--daemon" in sys.argv) or ("-d" in sys.argv)
    bus = open_bus()
    a = find(bus)
    d = None
    if a is not None:
        configure(bus, a)
        d = read_calib(bus, a)

    if not daemon:
        lux, lux_have = read_lux(bus)
        if a is None and not lux_have:
            publish(0.0, 0.0, 0.0, False, 0.0, False)
            print("no BME280 (0x77/0x76) or VEML7700 (0x10) found",
                  file=sys.stderr)
            return 1
        if a is not None:
            t, h, p = measure_forced(bus, a, d)
        else:
            t = h = p = 0.0
        publish(t, h, p, a is not None, lux, lux_have)
        parts = []
        if a is not None:
            parts.append("%.1f C   %.0f %%RH   %.1f hPa" % (t, h, p))
        if lux_have:
            parts.append("%.1f lux" % lux)
        print("   ".join(parts))
        return 0

    n = 0
    while True:
        n += 1
        if a is None:
            if n % 5 == 0:
                bus = bus or open_bus()
                a = find(bus)
                if a is not None:
                    configure(bus, a)
                    d = read_calib(bus, a)
        if a is not None:
            try:
                t, h, p = measure_forced(bus, a, d)
            except OSError:
                a = None
                t = h = p = 0.0
        else:
            t = h = p = 0.0
        lux, lux_have = read_lux(bus)
        publish(t, h, p, a is not None, lux, lux_have)
        time.sleep(2.0)


if __name__ == "__main__":
    try:
        sys.exit(main() or 0)
    except KeyboardInterrupt:
        pass
