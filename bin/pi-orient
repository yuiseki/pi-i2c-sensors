#!/usr/bin/env python3
"""pi-orient : publish device orientation (pitch + tilt-compensated heading)
from the MSA311 accelerometer + MMC5603 magnetometer.

Writes "<pitch_deg> <bearing_deg> <have_sensor>" to /dev/shm/pi-orientation
(tmpfs = RAM, so no microSD wear) ~15x/s. have_sensor is 1 when both chips
respond, else 0. Designed to run harmlessly on a Pi with NO sensors (or no I2C,
or no calibration): it never errors out, it just publishes have_sensor=0 and
keeps re-probing. Ctrl-C to quit.

Calibration (hard-iron offset + scale) is read once from ~/tmp/pi-calib.json;
if absent, identity calibration is used (bearing rough but no crash).
"""
import os, sys, time, math, json, pwd

try:
    from smbus2 import SMBus
except ImportError:
    try:
        from smbus import SMBus
    except ImportError:
        SMBus = None

A = 0x62          # MSA311 part id reg 0x01 == 0x13
M = 0x30          # MMC5603 product id reg 0x39 == 0x10
MAXPITCH = 60.0
OUT = "/dev/shm/pi-orientation"


def _envf(key, default):
    try:
        return float(os.environ[key])
    except (KeyError, ValueError):
        return default


# Capture big moves, ignore fine jitter: a deadband freezes the output until
# the change exceeds it (kills rest jitter), then EMA smooths the catch-up.
ALPHA = _envf("PI_ORIENT_ALPHA", 0.2)        # EMA factor while moving
PITCH_DB = _envf("PI_ORIENT_PITCH_DB", 3.0)  # ignore pitch changes below this (deg)
BEAR_DB = _envf("PI_ORIENT_BEAR_DB", 6.0)    # ignore bearing changes below this (deg)


def _user():
    return os.environ.get("SUDO_USER") or os.environ.get("USER") or "yuiseki"


try:
    HOME = pwd.getpwnam(_user()).pw_dir
except KeyError:
    HOME = "/home/yuiseki"
CALPATH = os.path.join(HOME, "tmp", "pi-calib.json")
NORTHPATH = os.path.join(HOME, "tmp", "pi-north")  # bearing offset (deg), set by pi-set-north


def load_north():
    try:
        return float(open(NORTHPATH).read().strip())
    except Exception:
        return 0.0


CARD = ("north", "east", "south", "west")


def _solve_linear(A, b):
    """Gauss-Jordan solve of a 3x3 system. Returns len-3 list or None."""
    n = 3
    M = [[A[r][c] for c in range(n)] + [b[r]] for r in range(n)]
    for col in range(n):
        piv = max(range(col, n), key=lambda r: abs(M[r][col]))
        if abs(M[piv][col]) < 1e-12:
            return None
        M[col], M[piv] = M[piv], M[col]
        pv = M[col][col]
        for c in range(col, n + 1):
            M[col][c] /= pv
        for r in range(n):
            if r != col:
                f = M[r][col]
                for c in range(col, n + 1):
                    M[r][c] -= f * M[col][c]
    return [M[r][n] for r in range(n)]


def _lsq3(M, y):
    """Least-squares fit of c so that M.c ~= y (M is Nx3) via normal equations."""
    AtA = [[sum(M[k][r] * M[k][c] for k in range(len(M))) for c in range(3)]
           for r in range(3)]
    Aty = [sum(M[k][r] * y[k] for k in range(len(M))) for r in range(3)]
    return _solve_linear(AtA, Aty)


def load_fit(plane):
    """Affine heading calibration from the 4 pi-cal-point captures of a plane.

    Needs pi-<plane>-{north,east,south,west}.json. Drops the near-constant
    (vertical) magnetometer axis, then least-squares fits an affine map of the
    two remaining axes to (cos, sin) of the true bearing -- correcting centre,
    per-axis scale, rotation and shear (needed e.g. when one horizontal axis is
    soft-iron compressed, as the mounted Z axis is). Returns a fit dict or None.
    """
    mags, trues = [], []
    for d in CARD:
        try:
            r = json.load(open(os.path.join(HOME, "tmp", "pi-%s-%s.json" % (plane, d))))
            mags.append(r["mag"])
            trues.append(math.radians(r["true_bearing"]))
        except Exception:
            return None
    rng = [max(m[a] for m in mags) - min(m[a] for m in mags) for a in range(3)]
    drop = rng.index(min(rng))            # near-constant axis = vertical
    i, j = [a for a in range(3) if a != drop]
    M = [[m[i], m[j], 1.0] for m in mags]
    cx = _lsq3(M, [math.cos(t) for t in trues])
    cy = _lsq3(M, [math.sin(t) for t in trues])
    if cx is None or cy is None:
        return None
    return {"axes": (i, j), "cx": cx, "cy": cy}


def apply_fit(fit, mc):
    i, j = fit["axes"]
    u, v = mc[i], mc[j]
    x = fit["cx"][0] * u + fit["cx"][1] * v + fit["cx"][2]
    y = fit["cy"][0] * u + fit["cy"][1] * v + fit["cy"][2]
    return math.degrees(math.atan2(y, x)) % 360.0


def s16(lo, hi):
    v = (hi << 8) | lo
    return v - 65536 if v >= 32768 else v


def u20(b0, b1, b2):
    return (b0 << 12) | (b1 << 4) | (b2 >> 4)


def open_bus():
    if SMBus is None:
        return None
    try:
        return SMBus(1)
    except PermissionError:
        os.execvp("sudo", ["sudo", sys.executable] + sys.argv)
    except (FileNotFoundError, OSError):
        return None


def probe(bus):
    if bus is None:
        return False
    try:
        return (bus.read_byte_data(A, 0x01) == 0x13 and
                bus.read_byte_data(M, 0x39) == 0x10)
    except OSError:
        return False


def init_sensors(bus):
    bus.write_byte_data(A, 0x11, 0x00)
    bus.write_byte_data(A, 0x0F, 0x00)
    bus.write_byte_data(A, 0x10, 0x08)
    bus.write_byte_data(M, 0x1C, 0x80)
    time.sleep(0.05)
    bus.write_byte_data(M, 0x1C, 0x00)
    time.sleep(0.02)


def load_cal():
    try:
        c = json.load(open(CALPATH))
        off = c["mag_offset"]
        scl = c["mag_scale"]
        ar = c.get("accel_rest", [0, 0, 1])
    except Exception:
        off, scl, ar = [0.0, 0.0, 0.0], [1.0, 1.0, 1.0], [0.0, 0.0, 1.0]
    n = math.sqrt(sum(v * v for v in ar)) or 1.0
    ar = [v / n for v in ar]
    rest_pitch = math.degrees(math.atan2(ar[1], ar[2]))
    return off, scl, ar, rest_pitch


def read_acc(bus):
    d = bus.read_i2c_block_data(A, 0x02, 6)
    return [s16(d[0], d[1]) / 16384.0, s16(d[2], d[3]) / 16384.0,
            s16(d[4], d[5]) / 16384.0]


def mag_raw(bus):
    bus.write_byte_data(M, 0x1B, 0x01)
    time.sleep(0.012)
    m = bus.read_i2c_block_data(M, 0x00, 9)
    return [u20(m[0], m[1], m[6]), u20(m[2], m[3], m[7]), u20(m[4], m[5], m[8])]


def field(bus):
    bus.write_byte_data(M, 0x1B, 0x08)
    time.sleep(0.004)
    s = mag_raw(bus)
    bus.write_byte_data(M, 0x1B, 0x10)
    time.sleep(0.004)
    r = mag_raw(bus)
    return [(s[i] - r[i]) / 2.0 / 16384.0 for i in range(3)]


def publish(pitch, bearing, have, extra=""):
    # Line: "<pitch> <bearing> <have> [<mcx> <mcy> <mcz> <ax> <ay> <az>]".
    # The map consumer reads only the first three tokens; the appended
    # calibrated-mag + accel fields let pi-cal-point capture references without
    # touching I2C (no contention with this process).
    tmp = OUT + ".tmp"
    try:
        with open(tmp, "w") as fh:
            fh.write("%.1f %.1f %d%s\n" % (pitch, bearing, 1 if have else 0, extra))
        os.replace(tmp, OUT)   # atomic on tmpfs
    except OSError:
        pass


def step_ang(cur, new):
    if cur is None:
        return new
    d = ((new - cur + 180) % 360) - 180
    if abs(d) < BEAR_DB:        # within deadband -> hold (ignore jitter)
        return cur
    return (cur + ALPHA * d) % 360


def step_lin(cur, new):
    if cur is None:
        return new
    d = new - cur
    if abs(d) < PITCH_DB:       # within deadband -> hold
        return cur
    return cur + ALPHA * d


def main():
    bus = open_bus()
    off, scl, arest, rest_pitch = load_cal()
    have = probe(bus)
    if have:
        init_sensors(bus)
    TTY = sys.stdout.isatty()   # suppress the live ANSI display under systemd
    print("pi-orient -> %s%s" % (OUT, "   (Ctrl-C to quit)" if TTY else ""))
    print("sensors: %s   calibration: %s"
          % ("present" if have else "ABSENT (publishing have=0)",
             "loaded" if os.path.exists(CALPATH) else "none (identity)"))
    if TTY:
        print("")
        print("")
    hdg = None
    pit = None
    last_probe = 0.0
    n = 0
    offset = load_north()
    hfit = load_fit("h")
    vfit = load_fit("v")
    try:
        while True:
            n += 1
            # cheap periodic re-probe so hot-plug / late wiring is picked up
            if not have and (n % 20 == 0):
                bus = bus or open_bus()
                have = probe(bus)
                if have:
                    init_sensors(bus)

            if not have:
                publish(0.0, 0.0, False)
                if TTY:
                    sys.stdout.write("\033[2A\r\033[2K no sensors detected (have=0)\n\033[2K\n")
                    sys.stdout.flush()
                time.sleep(0.25)
                continue

            try:
                a = read_acc(bus)
                m = field(bus)
            except OSError:
                have = False        # dropped off the bus
                continue

            mc = [(m[i] - off[i]) * scl[i] for i in range(3)]
            an = math.sqrt(sum(v * v for v in a)) or 1.0
            ax, ay, az = (a[0] / an, a[1] / an, a[2] / an)

            # Map pitch is 0..60 (no negative), so use the UNSIGNED tilt angle
            # away from the resting pose: any tilt direction pitches the map,
            # and nothing is lost to the >=0 clamp. (A signed single-axis pitch
            # left half its range clamped to 0 and barely moved the map.)
            dot = max(-1.0, min(1.0, ax * arest[0] + ay * arest[1] + az * arest[2]))
            pitch_signed = math.degrees(math.acos(dot))   # 0 at rest, grows w/ tilt

            # Heading from the horizontal X-Y axes only (the mount's Z axis is
            # soft-iron compressed, so no tilt compensation). With a 4-point
            # horizontal calibration (pi-cal-point N/E/S/W) use its residual
            # hard-iron centre + rotation offset; otherwise fall back to the raw
            # heading minus the pi-set-north offset.
            mx, my, mz = mc
            # Horizontal (flat) uses the h-plane fit, upright uses the v-plane
            # fit (gravity az picks which). Each affine fit already encodes the
            # right two axes + scale + offset for that pose.
            fit = hfit if abs(az) >= 0.6 else vfit
            if fit is not None:
                heading = apply_fit(fit, mc)
            else:                           # no calibration yet: rough fallback
                heading = (math.degrees(math.atan2(my, mx)) - offset) % 360

            pit = step_lin(pit, pitch_signed)
            hdg = step_ang(hdg, heading)
            if n % 25 == 0:                 # pick up pi-set-north changes live
                offset = load_north()
            if n % 125 == 0:                # pick up new pi-cal-point captures
                hfit = load_fit("h")
                vfit = load_fit("v")
            extra = " %.4f %.4f %.4f %.4f %.4f %.4f" % (mc[0], mc[1], mc[2], ax, ay, az)
            publish(pit, hdg, True, extra)

            if TTY:
                sys.stdout.write("\033[2A\r\033[2K TILT(pitch) = %5.1f deg   BEARING = %5.1f deg   (have=1)\n"
                                 % (pit, bout))
                sys.stdout.write("\033[2K -> %s\n" % OUT)
                sys.stdout.flush()
            time.sleep(0.04)
    except KeyboardInterrupt:
        print("\n\nbye")


if __name__ == "__main__":
    sys.exit(main())
